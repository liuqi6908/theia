{
  "private": true,
  "name": "theia",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "postinstall": "theia check:theia-version",
    "prepare": "pnpm --parallel --filter \"theia-extension-*\" prepare",
    "plugins": "pnpm --filter theia-electron plugins",
    "watch": "pnpm --parallel --filter \"theia-extension-*\" --filter theia-electron watch",
    "start": "pnpm --filter theia-electron start",
    "build": "pnpm --filter theia-electron bundle"
  },
  "devDependencies": {}
}
