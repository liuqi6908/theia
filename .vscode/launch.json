{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "运行 Stata Preview 扩展",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/vscode/stata-preview"
