{
  "private": true,
  "name": "theia-electron",
  "productName": "ChatPython",
  "version": "0.0.2",
  "main": "lib/backend/electron-main.js",
  "dependencies": {
    "@theia/bulk-edit": "1.71.1",
    "@theia/callhierarchy": "1.71.1",
    "@theia/console": "1.71.1",
    "@theia/core": "1.71.1",
    "@theia/debug": "1.71.1",
    "@theia/editor": "1.71.1",
    "@theia/editor-preview": "1.71.1",
    "@theia/electron": "1.71.1",
    "@theia/external-terminal": "1.71.1",
    "@theia/file-search": "1.71.1",
    "@theia/filesystem": "1.71.1",
    "@theia/markers": "1.71.1",
    "@theia/messages": "1.71.1",
    "@theia/monaco": "1.71.1",
    "@theia/navigator": "1.71.1",
    "@theia/notebook": "1.71.1",
    "@theia/outline-view": "1.71.1",
    "@theia/output": "1.71.1",
    "@theia/plugin-ext": "1.71.1",
    "@theia/plugin-ext-vscode": "1.71.1",
    "@theia/preferences": "1.71.1",
    "@theia/process": "1.71.1",
    "@theia/scm": "1.71.1",
    "@theia/search-in-workspace": "1.71.1",
    "@theia/task": "1.71.1",
    "@theia/terminal": "1.71.1",
    "@theia/terminal-manager": "1.71.1",
    "@theia/test": "1.71.1",
    "@theia/timeline": "1.71.1",
    "@theia/typehierarchy": "1.71.1",
    "@theia/userstorage": "1.71.1",
    "@theia/variable-resolver": "1.71.1",
    "@theia/vsx-registry": "1.71.1",
    "@theia/workspace": "1.71.1",
    "theia-extension-plugin-register": "workspace:^",
    "theia-extension-splash-screen": "workspace:^",
    "theia-extension-app-updater": "workspace:^",
    "theia-extension-workbench-layout": "workspace:^",
    "theia-extension-zh-cn-language-pack": "workspace:^"
  },
  "devDependencies": {
    "@theia/cli": "1.71.1",
    "concurrently": "^9.2.1",
    "electron": "39.8.7",
    "electron-builder": "^26.8.1"
  },
  "scripts": {
    "bundle": "pnpm rebuild && theia build --mode development",
    "build": "pnpm bundle && electron-builder -c.mac.identity=null --publish never",
    "build:preview": "pnpm bundle && electron-builder --dir -c.mac.identity=null --publish never",
    "build:mac": "pnpm bundle && electron-builder --mac -c.mac.identity=null --publish never",
    "build:win": "pnpm bundle && electron-builder --win --publish never",
    "deploy": "pnpm bundle && electron-builder --publish always",
    "plugins:download": "theia download:plugins --rate-limit=15 --parallel=false && pnpm plugins:prune && pnpm plugins:permissions",
    "plugins:permissions": "node scripts/make-files-writeable.js --directory plugins",
    "rebuild": "theia rebuild:electron --cacheRoot ..",
    "start": "theia start --plugins=local-dir:plugins",
    "watch": "pnpm rebuild && theia build --watch --mode development"
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {
    "vscode-builtin-extensions": "https://github.com/eclipse-theia/vscode-builtin-extensions/releases/download/1.108.2/vscode-builtin-extensions-1.108.2.tar.gz",
    "ms-ceintl.vscode-language-pack-zh-hans": "https://open-vsx.org/api/MS-CEINTL/vscode-language-pack-zh-hans/1.110.0/file/MS-CEINTL.vscode-language-pack-zh-hans-1.110.0.vsix",
    "vscode-extension-stata-preview": "https://chatpython-src.qiyansoft.com/extension/stata-preview/0.0.1/vscode-extension-stata-preview-0.0.1.vsix"
  },
  "theiaPluginsExcludeIds": [
    "vscode.github",
    "vscode.github-authentication",
    "vscode.extension-editing"
  ],
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "ChatPython",
        "defaultLocale": "zh-cn",
        "reloadOnReconnect": true
      }
    }
  }
}
